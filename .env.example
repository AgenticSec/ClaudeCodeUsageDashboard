# Copy this file to ~/.claude-code-usage-dashboard/env
#
#   mkdir -p ~/.claude-code-usage-dashboard
#   cp .env.example ~/.claude-code-usage-dashboard/env
#

# Dashboard URL (default: http://localhost:5173)
CLAUDE_CODE_USAGE_DASHBOARD_URL=

# Allowed project directories (comma-separated, fnmatch patterns supported)
# If unset, all projects are allowed.
# Examples:
#   /Users/me/work/*                    — all projects under ~/work
#   /Users/me/work/*,/Users/me/oss/*    — work and oss directories
#   /Users/me/work/project-a            — exact match only
CLAUDE_CODE_USAGE_DASHBOARD_ALLOWED_DIRS=
